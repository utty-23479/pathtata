{
  "product": "PATHTATA_SORTING_HAT",
  "version": "beta-1",
  "language": "en",

  "scoring_model": {
    "technical": {
      "question_ids": ["T1", "T2", "T3", "T4", "T5", "T6"],
      "points": {
        "correct": 1.0,
        "incorrect": 0.0,
        "not_sure": -0.25
      },
      "not_sure_option_key": "E",
      "normalize": {
        "raw_min": -1.5,
        "raw_max": 6.0,
        "formula": "((raw - raw_min) / (raw_max - raw_min)) * 100"
      },
      "levels": [
        {
          "id": "explorer",
          "technical_name": "Initial / Exploratory",
          "min": 0,
          "max": 34,
          "gamified": {
            "name": "Explorer",
            "description": "The hat senses curiosity. You are at the beginning of your technology journey, exploring how different paths work.",
            "cta": "Your journey begins with strong foundations."
          }
        },
        {
          "id": "apprentice",
          "technical_name": "Junior",
          "min": 35,
          "max": 64,
          "gamified": {
            "name": "Apprentice",
            "description": "The hat recognizes growing skills. You understand core concepts and are ready to build real-world solutions with practice.",
            "cta": "Focus your learning and keep practicing — progress is close."
          }
        },
        {
          "id": "path_seeker",
          "technical_name": "Junior–Intermediate",
          "min": 65,
          "max": 100,
          "gamified": {
            "name": "Path Seeker",
            "description": "The hat sees clarity and direction. You can reason about problems and are ready to commit to a path with confidence.",
            "cta": "Choose your path and start mastering it."
          }
        }
      ],
      "confidence": {
        "formula": "1 - (not_sure_count / 6)",
        "labels": [
          { "name": "High", "min": 0.8 },
          { "name": "Medium", "min": 0.5 },
          { "name": "Low", "min": 0.0 }
        ]
      }
    },

    "paths": {
      "available": [
        "Fullstack / Backend",
        "Data Engineer",
        "DevOps / Cloud",
        "Foundations / Exploratory"
      ],
      "weights": {
        "technical": 0.7,
        "preferences": 0.3
      },
      "gating": {
        "foundations_if_technical_score_below": 35
      }
    }
  },

  "preference_mapping": {
    "NT1": {
      "A": { "Fullstack / Backend": 1.0 },
      "B": { "Data Engineer": 1.0 },
      "C": { "DevOps / Cloud": 1.0 },
      "D": { "DevOps / Cloud": 0.5, "Fullstack / Backend": 0.5 }
    },
    "NT2": {
      "A": { "Data Engineer": 1.0 },
      "B": { "Fullstack / Backend": 1.0 },
      "C": {
        "Fullstack / Backend": 0.5,
        "Data Engineer": 0.5,
        "DevOps / Cloud": 0.5
      },
      "D": { "DevOps / Cloud": 1.0 }
    },
    "NT3": {
      "A": { "Data Engineer": 1.0 },
      "B": { "Fullstack / Backend": 1.0 },
      "C": { "DevOps / Cloud": 1.0 },
      "D": { "Data Engineer": 1.0 }
    },
    "NT4": {
      "A": { "Fullstack / Backend": 1.0 },
      "B": { "Data Engineer": 1.0 },
      "C": { "DevOps / Cloud": 1.0 },
      "D": {
        "Fullstack / Backend": 0.5,
        "Data Engineer": 0.5,
        "DevOps / Cloud": 0.5
      }
    }
  },

  "question_order": [
    "T1", "NT1",
    "T2", "NT2",
    "T3", "NT3",
    "T4", "NT4",
    "T5", "T6"
